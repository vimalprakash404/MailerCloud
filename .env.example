# ==============================================================================
# MailerCloud Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and modify as needed.
# Note: The Go backend reads environment variables directly from the shell.
# To load these on startup locally, you can export them or prepend them to the command.
# E.g. (Linux/macOS): export $(xargs < .env)
# E.g. (PowerShell): Get-Content .env | Foreach-Object { $name, $value = $_ -split '=', 2; [System.Environment]::SetEnvironmentVariable($name, $value) }
# ==============================================================================

# ─── BACKEND HTTP SERVER ──────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── DATABASE (MYSQL) ─────────────────────────────────────────────────────────
# Use DB_PORT=3307 if running MySQL via docker compose Option A (mapped port)
# Use DB_PORT=3306 if running MySQL natively on the host machine
DB_HOST=localhost
DB_PORT=3307
DB_USER=mailercloud
DB_PASSWORD=mailercloud
DB_NAME=mailercloud

# Connection Pool Settings
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=25

# ─── QUEUE (REDIS) ────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_POOL_SIZE=200
REDIS_MIN_IDLE_CONNS=50

# ─── INGESTION BATCHER ────────────────────────────────────────────────────────
# Maximum events to buffer before writing a batch to the database
BATCH_SIZE=2000
# Flush interval in milliseconds
FLUSH_INTERVAL_MS=500
# Number of parallel workers flushing event batches to the database
NUM_WORKERS=8

# ─── CLI LOAD GENERATOR ───────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8080
CAMPAIGN_ID=camp-1
TOTAL_EVENTS=20000
CONCURRENCY=50
# Batch size for loadgen requests (sent in bulk POST /events/batch)
LOADGEN_BATCH_SIZE=200
