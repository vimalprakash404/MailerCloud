# MailerCloud Load Generator Configuration

# The API URL of the MailerCloud backend service
BACKEND_URL=http://localhost:8080

# The ID of the campaign to receive simulated traffic
CAMPAIGN_ID=camp-1

# The total number of events to generate (sent, opened, clicked, bounced)
TOTAL_EVENTS=2000000

# Concurrency level (number of concurrent worker goroutines firing requests)
CONCURRENCY=20000


