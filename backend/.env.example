# ─── BACKEND HTTP SERVER ──────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── DATABASE (MYSQL) ─────────────────────────────────────────────────────────
# Use DB_PORT=3307 if running MySQL via Docker Compose (Option A)
# Use DB_PORT=3306 if running MySQL natively on the host (Option B)
DB_HOST=localhost
DB_PORT=3307
DB_USER=mailercloud
DB_PASSWORD=mailercloud
DB_NAME=mailercloud

# Connection Pool Settings
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=25

# ─── QUEUE (REDIS) ────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_POOL_SIZE=200
REDIS_MIN_IDLE_CONNS=50

# ─── INGESTION BATCHER ────────────────────────────────────────────────────────
# Maximum events to buffer before writing a batch to the database
BATCH_SIZE=2000
# Flush interval in milliseconds
FLUSH_INTERVAL_MS=500
# Number of parallel workers flushing event batches to the database
NUM_WORKERS=8
